---
import Layout from '../../layouts/Layout.astro';

// TODO Resolve repo link font size (use a dedicated utility/class for table links instead of inheriting cell text size).
// TODO Hook up to authenticated GitHub calls via process.env (read server-side env vars with Astro and call GitHub API with Authorization header).
// TODO Figure out authenticated tokens in GitHub builds (store token as GitHub Actions secret and expose only to server/runtime steps).
// TODO Ensure builds run nightly via cron (add a scheduled GitHub Actions workflow with `on.schedule` cron expression).
// TODO Review implementation including horizontal scroll behavior (verify mobile overflow, sticky affordances, and no clipped borders).
// TODO Revise copy and ensure lowercase header (update page intro/table labels and keep heading text casing consistent with site voice).

const projects = [
  {
    title: 'siteify',
    description: 'Theme toggles and styling primitives for fast personal site customization.',
    repoLink: 'https://github.com/nirmal-mekala/siteify',
    livePreviewLink: 'https://nirmal.site/siteify',
    createdDate: '2023-08-14',
    updatedDate: '2026-01-28',
    tags: ['theming', 'ui', 'javascript'],
  },
  {
    title: 'grows tree',
    description: 'An interactive visual summary of growth over time mapped to a tree.',
    repoLink: 'https://github.com/nirmal-mekala/nirmal-mekala.github.io',
    livePreviewLink: 'https://nirmal.site/grows',
    createdDate: '2024-06-09',
    updatedDate: '2026-02-22',
    tags: ['astro', 'react', 'visualization'],
  },
  {
    title: 'portfolio sandbox',
    description: 'A playground for testing portfolio content, layout ideas, and experiments.',
    repoLink: 'https://github.com/nirmal-mekala/portfolio-sandbox',
    livePreviewLink: 'https://preview.nirmal.site',
    createdDate: '2025-01-17',
    updatedDate: '2026-02-24',
    tags: ['experiments', 'design', 'content'],
  },
];

const githubRepo = 'nirmal-mekala/nirmal-mekala.github.io';
const githubApiUrl = `https://api.github.com/repos/${githubRepo}`;

let githubRepoSummary: {
  name: string;
  stars: number;
  forks: number;
  openIssues: number;
  lastPushAt: string;
  repoUrl: string;
} | null = null;

console.log(`[builds:ssr] Starting server-side GitHub fetch for ${githubRepo}`);

try {
  const response = await fetch(githubApiUrl, {
    headers: {
      Accept: 'application/vnd.github+json',
      Authorization: `Bearer ${import.meta.env.GH_TOKEN}`,
    },
  });

  if (!response.ok) {
    throw new Error(`GitHub API request failed with status ${response.status}`);
  }

  const repo = await response.json();
  githubRepoSummary = {
    name: repo.full_name,
    stars: repo.stargazers_count,
    forks: repo.forks_count,
    openIssues: repo.open_issues_count,
    lastPushAt: repo.pushed_at,
    repoUrl: repo.html_url,
  };

  console.log(
    `[builds:ssr] GitHub fetch completed on server. stars=${githubRepoSummary.stars}, forks=${githubRepoSummary.forks}`,
  );
} catch (error) {
  console.error('[builds:ssr] GitHub fetch failed on server:', error);
}
---

<Layout>
  <p>coming soon...</p>
  <p style="display: none;">{githubRepoSummary ? githubRepoSummary.name : 'failure'}</p>
</Layout>
