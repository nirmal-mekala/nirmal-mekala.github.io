---
import Layout from '../../layouts/Layout.astro';

const fetchRepo = async (repoName: string) => {
  console.log(`[builds:ssr] Starting server-side GitHub fetch for ${repoName}`);
  try {
    const response = await fetch(`https://api.github.com/repos/nirmal-mekala/${repoName}`, {
      headers: {
        Accept: 'application/vnd.github+json',
        Authorization: `Bearer ${import.meta.env.GH_TOKEN}`,
      },
    });
    if (!response.ok) {
      throw new Error(`GitHub API request failed with status ${response.status}`);
    }
    const repo = await response.json();
    console.log(`[builds:ssr] GitHub fetch for ${repo.name} completed on server.`);
    return repo;
  } catch (error) {
    console.error('[builds:ssr] GitHub fetch failed on server:', error);
    return null;
  }
};

const staticProjectMetadata = [
  {
    repoName: '260319-strategy-walkthrough',
    previewUrl: 'https://github.com/nirmal-mekala/260319-strategy-walkthrough',
    tags: ['site', 'poc'],
  },
  {
    repoName: '260414-next-exploration',
    previewUrl: 'https://260414-next-exploration.vercel.app/',
    tags: ['app', 'poc'],
  },
  { repoName: 'loggy', tags: ['tool', 'cli'] },
  {
    repoName: 'nirmal-mekala.github.io',
    previewUrl: 'https://nirmal.meka.la',
    tags: ['site'],
  },
  {
    repoName: 'siteify',
    previewUrl: 'https://nirmal.meka.la/siteify',
    tags: ['tool'],
  },

  {
    repoName: 'works',
    previewUrl: 'https://nirmal.meka.la/works',
    tags: ['site'],
  },
  {
    repoName: 'plot-csv',
    previewUrl: 'https://nirmal.meka.la/plot-csv',
    tags: ['tool'],
  },
  { repoName: 'v1', previewUrl: 'https://nirmal.meka.la/v1', tags: ['bootcamp', 'site'] },
  { repoName: 'shopping-cart-2', previewUrl: 'https://nirmal.meka.la/shopping-cart-2', tags: ['bootcamp', 'app'] },
  { repoName: 'memory', previewUrl: 'https://nirmal.meka.la/memory', tags: ['bootcamp', 'app'] },
  { repoName: 'cvapp', previewUrl: 'https://nirmal.meka.la/cvapp', tags: ['bootcamp', 'app'] },
  { repoName: 'todo', previewUrl: 'https://nirmal.meka.la/todo', tags: ['bootcamp', 'app'] },
  { repoName: 'weather', previewUrl: 'https://nirmal.meka.la/weather', tags: ['bootcamp', 'app'] },
  { repoName: 'calculator', previewUrl: 'https://nirmal.meka.la/calculator', tags: ['bootcamp', 'app'] },
  { repoName: 'etch-a-sketch', previewUrl: 'https://nirmal.meka.la/etch-a-sketch', tags: ['bootcamp', 'app'] },
  { repoName: '250707-barcode', previewUrl: 'https://nirmal.meka.la/250707-barcode', tags: ['poc', 'app'] },
  { repoName: 'obs', previewUrl: 'https://nirmal.meka.la/obs', tags: ['tool', 'site'] },
  { repoName: 'dotfiles', previewUrl: null, tags: ['tool'] },
  { repoName: 'wizardry', previewUrl: null, tags: ['cli', 'tool'] },
  { repoName: 'word-counter', previewUrl: null, tags: ['cli', 'tool'] },
  { repoName: 'checklist-generator', previewUrl: null, tags: ['cli', 'tool'] },
  { repoName: 'nas-docker', previewUrl: null, tags: ['selfhosting'] },
  { repoName: 'tic-tac-toe', previewUrl: 'https://nirmal.meka.la/tic-tac-toe', tags: ['bootcamp', 'app'] },
  {
    repoName: 'rock-paper-scissors',
    previewUrl: 'https://nirmal.meka.la/rock-paper-scissors',
    tags: ['bootcamp', 'app'],
  },
  { repoName: 'book', previewUrl: 'https://nirmal.meka.la/book', tags: ['bootcamp', 'app'] },
];

const projects = (
  await Promise.all(
    staticProjectMetadata.map(async (staticRepoData) => {
      const ghData = await fetchRepo(staticRepoData.repoName);
      if (!ghData) return null;
      return {
        ...staticRepoData,
        description: ghData.description,
        html_url: ghData.html_url,
        created_at: ghData.created_at,
        pushed_at: ghData.pushed_at,
      };
    }),
  )
)
  .filter(Boolean)
  .sort((a, b) => new Date(b.pushed_at) - new Date(a.pushed_at));
---

<Layout>
<h1>builds</h1>
<p>Below are the projects I’ve posted publicly on GitHub. Early on this was mostly projects for bootcamp, but as time went on I published a number of personal tools I use. More projects coming!</p>
  <div class="!my-6 overflow-x-auto">
    <table data-builds-table class="min-w-full border-collapse border text-[0.875rem]">
      <thead>
        <tr>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">Title</th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">Description</th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">Repo</th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">Live Preview</th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">
            <div class="flex items-center gap-2">
              <span>Created Date</span>
              <button
                type="button"
                data-sort-key="created_at"
                data-sort-column="4"
                data-sort-direction="asc"
                aria-label="Sort by created date"
                aria-pressed="false"
                class="inline-flex h-6 w-6 items-center justify-center rounded-full border-2 text-[0.75rem] leading-none cursor-pointer"
              >
                ↑
              </button>
            </div>
          </th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">
            <div class="flex items-center gap-2">
              <span>Last Push</span>
              <button
                type="button"
                data-sort-key="pushed_at"
                data-sort-column="5"
                data-sort-direction="desc"
                aria-label="Sort by last push date"
                aria-pressed="true"
                class="inline-flex h-6 w-6 items-center justify-center rounded-full border-2 text-[0.75rem] leading-none cursor-pointer"
              >
                ↓
              </button>
            </div>
          </th>
          <th class="border px-3 py-2 text-left font-semibold" aria-sort="none">Tags</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((project) => (
          <tr>
            <td class="border px-3 py-3 font-medium">{project.repoName}</td>
            <td class="border px-3 py-3">{project.description}</td>
            <td class="border px-3 py-3">
              <a class="text-[0.875rem]! cursor before:content-none!" href={project.html_url} target="_blank" rel="noreferrer">repo</a>
            </td>
            <td class="border px-3 py-3">
              {project.previewUrl && 
                <a class="text-[0.875rem]! cursor before:content-none!" href={project.previewUrl} target="_blank" rel="noreferrer">preview</a>
              }
            </td>
            <td data-sort-value={project.created_at} data-date-cell class="border px-3 py-3 whitespace-nowrap">{project.created_at}</td>
            <td data-sort-value={project.pushed_at} data-date-cell class="border px-3 py-3 whitespace-nowrap">{project.pushed_at}</td>
            <td class="border px-3 py-3">
              <div class="flex flex-wrap">
                {project.tags.map((tag) => <code class="block text-[0.875rem]! m-1!">{tag}</code>)}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <script>
    // TODO move this to a React comp, this got chaotic.
    const table = document.querySelector('[data-builds-table]');
    const tbody = table?.querySelector('tbody');
    const sortButtons = Array.from(table?.querySelectorAll('button[data-sort-key]') ?? []);


    function formatDate(dateString) {
      const date = new Date(dateString);
      return date.toLocaleDateString('en-US', {
        month: 'numeric',
        day: 'numeric',
        year: '2-digit',
      });
    };

    const dateCells = Array.from(table?.querySelectorAll('[data-date-cell]') ?? []);
    dateCells.forEach((cell) => {
      const dateValue = cell.getAttribute('data-sort-value') ?? '';
      cell.textContent = formatDate(dateValue);
    });

    if (table && tbody && sortButtons.length > 0) {
      let activeSortKey = 'pushed_at';
      let LAST_PUSH_COLUMN_INDEX = 5

      const updateHeaderSortState = (columnIndex, sortDirection) => {
        const headers = table.querySelectorAll('thead th');
        headers.forEach((header, idx) => {
          header.setAttribute('aria-sort', idx === columnIndex ? (sortDirection === 'asc' ? 'ascending' : 'descending') : 'none');
        });
      };

      const updateButtonStyle = (button, isActive, direction) => {
        button.textContent = direction === 'asc' ? '↑' : '↓';
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        button.classList.toggle('bg-[var(--bg-color-3)]', isActive);
        button.classList.toggle('border-[var(--fg-color-3)]', isActive);
        button.classList.toggle('text-[var(--fg-color-3)]', isActive);
        button.classList.toggle('bg-[var(--bg-color-1)]', !isActive);
        button.classList.toggle('border-[var(--fg-color-1)]', !isActive);
        button.classList.toggle('text-[var(--fg-color-1)]', !isActive);
      };

      sortButtons.forEach((button) => {
        const key = button.getAttribute('data-sort-key') ?? '';
        const isActive = key === activeSortKey;
        const direction = button.getAttribute('data-sort-direction') ?? 'asc';
        updateButtonStyle(button, isActive, direction);
        button.addEventListener('click', () => {
          const sortKey = button.getAttribute('data-sort-key') ?? '';
          const columnIndex = Number(button.getAttribute('data-sort-column'));
          if (Number.isNaN(columnIndex)) return;
          const currentDirection = button.getAttribute('data-sort-direction') ?? 'asc';
          const nextDirection = activeSortKey === sortKey && currentDirection === 'asc' ? 'desc' : 'asc';
          activeSortKey = sortKey;

          sortButtons.forEach((otherButton) => {
            const isActive = otherButton === button;
            const direction = isActive ? nextDirection : 'asc';
            otherButton.setAttribute('data-sort-direction', direction);
            updateButtonStyle(otherButton, isActive, direction);
          });

          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort((rowA, rowB) => {
            const valueA = Date.parse(rowA.children[columnIndex]?.getAttribute('data-sort-value') ?? '');
            const valueB = Date.parse(rowB.children[columnIndex]?.getAttribute('data-sort-value') ?? '');
            const safeA = Number.isNaN(valueA) ? 0 : valueA;
            const safeB = Number.isNaN(valueB) ? 0 : valueB;
            const result = safeA - safeB;
            return nextDirection === 'asc' ? result : -result;
          });

          rows.forEach((row) => tbody.appendChild(row));
          updateHeaderSortState(columnIndex, nextDirection);
        });
      });
      updateHeaderSortState(LAST_PUSH_COLUMN_INDEX, 'desc');
    }
  </script>
</Layout>
